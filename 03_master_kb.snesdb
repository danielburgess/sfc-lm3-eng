[SECTION:sa1_arithmetic_unit_detailed]
modes=multiply|divide|cumulative_sum
multiply_form=signed_16bit_x_signed_16bit_=_signed_32bit
divide_form=signed_16bit_/_unsigned_16bit_=_signed_16bit_quotient_+_unsigned_16bit_remainder
cumulative_sum_form=accumulates_into_signed_40bit_register
trigger=write_to_$2254_(MB_high)
result_at=$2306..$230A
multiply_result_in=$2306..$2309_(32bit)
divide_quotient_in=$2306..$2307|remainder_$2308..$2309
cumulative_sum_in=$2306..$230A_(40bit)
overflow_flag=$230B.D7
clear_accumulator=write_$01_to_$2250.D1_(ACM)_to_clear_then_back_to_$00_to_re-enable
> The arithmetic unit is much more capable than the main CPU's hardware
> multiply: signed 16x16 with 32-bit result, signed 16/16 division, AND
> a 40-bit accumulator for sum-of-products. Used for matrix transforms,
> 3D geometry, and physics calculations. The accumulator survives between
> writes so you can chain (a*b + c*d + e*f + ...) by writing operands
> and adding partial products into the same accumulator.
typical_use=Super_Mario_RPG_uses_for_isometric_coord_transform|Kirby_Super_Star_for_sprite_scaling

[SECTION:sa1_charconv_dma]
mode_1=BWRAM_to_IRAM_with_format_conversion
mode_2=SA-1_writes_BWRAM_in_bitmap_form_then_charconv_unpacks_into_IRAM
formats_supported=2bpp|4bpp|8bpp_planar_output
horiz_chars=1|2|4|8|16|32_per_row
trigger_mode_1=set_$2230_DCNT|set_$2231_CDMA_with_size_and_color|set_$2232..$2237_addresses|writing_$2236_starts_DMA_to_IRAM
trigger_mode_2=set_DCNT_and_CDMA|then_write_to_BRF_$2240..$224F_to_provide_data_byte_at_a_time
purpose=fast_decompression_of_compressed_bitmap_into_planar_PPU_format
> The charconv DMA is the killer feature of SA-1. The PPU expects tile
> data in a planar format (bit 0 of all 8 pixels in byte 0, bit 1 in
> byte 1, etc.) which is awkward to compute. The SA-1 can take a
> "linear" bitmap (one byte per pixel pair) and emit planar tile data
> via DMA in one shot. This makes streaming compressed graphics into
> VRAM much faster than software unpacking.

[SECTION:sa1_varlen_bit_processing]
purpose=read_ROM_as_bit_stream_for_compression_decode
setup=write_VBD_$2258_with_bit_count_(1..16)|write_VDA_$2259..$225B_with_starting_ROM_address
read_pattern=read_VDP_$230C_$230D_for_next_n_bits|barrel_shifter_advances_by_n_automatically
common_use=Huffman_codeword_extraction|LZ_back_reference_offsets|RLE_run_lengths
> The variable-length bit unit is a hardware barrel shifter for reading
> ROM as a stream of arbitrary-bit-width values. Set the bit count to N
> (1-16), and each VDP read returns the next N bits and advances the
> position. Critical for fast decompression: instead of writing software
> to mask, shift, and merge bytes manually, you just read VDP to get
> the next codeword.

# =============================================================================
# === SUPER FX (GSU) — DETAILED ===============================================
# =============================================================================

[SECTION:gsu_overview_v3]
chip_name=Super_FX|core_name=GSU_(Graphic_Support_Unit)
versions=GSU1_(Star_Fox)|GSU2_(Doom,_Yoshi's_Island)|GSU2_is_pin_compatible_with_higher_clock
clock_default=10.74_MHz_(GSU1)
clock_high=21.4_MHz_(GSU2,_via_CLSR=1)
architecture=RISC-like|1_byte_instructions|cache_executes_in_1_cycle
cache=512_bytes_internal|loaded_via_CACHE_or_LJMP_instruction
register_file=16_x_16bit_(R0..R15)
parallel_with_main=yes
gamepak_ram_max=128_KiB
backup_ram_max=128_KiB
purpose=fast_3D_polygon_rendering|texture_mapping|sprite_scaling|frame_buffer_manipulation
games_using=Star_Fox|Star_Fox_2|Yoshi's_Island|Stunt_Race_FX|Doom|Vortex|Dirt_Trax_FX|Dirt_Racer|Winter_Gold|Power_Slide|Soul_Blader|FX_Fighter
> Super FX is a custom RISC processor designed by Argonaut Software. It
> runs at 10.74 MHz (or 21.4 MHz on GSU2) and has its own dedicated bus
> arbitration with the main CPU. The chip is designed for FAST integer
> math and pixel plotting — its claim to fame is the polygon and bitmap
> rendering in Star Fox and the sprite scaling/rotation in Yoshi's Island.

[SECTION:gsu_register_file]
R0=default_source_dest|init_$0000
R1=PLOT_X_coordinate|init_$0000
R2=PLOT_Y_coordinate|init_$0000
R3=general
R4=lower_16_bits_of_LMULT_result_(32bit_signed_multiply)
R5=general
R6=FMULT_LMULT_multiplier_operand
R7=MERGE_source_1
R8=MERGE_source_2
R9_R10=general
R11=LINK_destination_(set_by_LINK_instruction_for_subroutine_return)
R12=LOOP_counter_(decremented_by_LOOP_instruction)
R13=LOOP_branch_target
R14=ROM_address_pointer_(automatic_buffering_for_ROM_data_reads)
R15=Program_Counter|writing_to_R15_from_main_STARTS_GSU_execution
all_visible_to_main=$00..$3F:$3000..$301F|each_register_2_bytes
> The 16 GPRs have several special purposes. R1 and R2 are the X/Y
> coordinates for the PLOT pixel-write instruction. R4 holds the high
> word of LMULT (32-bit signed multiply). R6 is the second operand of
> FMULT/LMULT. R11 is the LINK return address. R12/R13 implement loops.
> R14 is the ROM read pointer with automatic buffering — reading R14
> after writing it triggers a ROM fetch. R15 IS the program counter,
> and writing to R15 from the main CPU is what STARTS the GSU running
> at the new address.

[SECTION:gsu_register_addresses]
window=$00..$3F:$3000..$32FF|and|$80..$BF:$3000..$32FF
$3000_$3001=R0|$3002_$3003=R1|...|$301E_$301F=R15
$3030_$3031=SFR|status_flag_register
$3033=BRAMR|backup_RAM_enable
$3034=PBR|program_bank|main_W|set_before_starting_GSU
$3036=ROMBR|ROM_data_bank|main_R_only|controls_R14_reads
$3037=CFGR|config|D5=multiplier_speed|D7=IRQ_mask
$3038=SCBR|screen_base|set_before_starting_GSU
$3039=CLSR|clock_select|D0=21.4MHz_high
$303A=SCMR|screen_mode|D4=RON|D3=RAN|see_below
$303B=VCR|version_code
$303C=RAMBR|RAM_data_bank|main_R_only|D0_picks_$70_or_$71
$303E_$303F=CBR|cache_base|main_R_only|set_by_CACHE_or_LJMP

[SECTION:gsu_sfr_flags]
$3030_$3031=SFR_status_flag_register|16_bit
D1=Z_zero
D2=CY_carry
D3=S_sign
D4=OV_overflow
D5=G_GO_flag|when_set_GSU_is_running|cleared_by_STOP_instruction
D6=R_set_when_R14_is_being_read_from_ROM
D8=ALT1_alternate_mode_for_next_instruction
D9=ALT2_alternate_mode_for_next_instruction
D10=IL_immediate_lower_8bit_flag
D11=IH_immediate_higher_8bit_flag
D12=BIRQ_set_by_WITH_instruction
D15=interrupt_flag
> The G flag is the "is GSU running" indicator. Main CPU polls this to
> wait for GSU completion. The ALT flags are set by ALT1/ALT2/ALT3
> prefix instructions and modify the meaning of the next opcode (used
> to expand the 1-byte opcode space).

[SECTION:gsu_scmr_screen_mode]
$303A=SCMR|screen_mode_and_bus_arbitration
D0=MD0|D1=MD1|color_mode_2bits
D2=HT0|D5=HT1|height_2bits
D3=RAN|RAM_bus_owner|0=main_owns|1=GSU_owns
D4=RON|ROM_bus_owner|0=main_owns|1=GSU_owns
height_table.HT1_HT0=00:128|01:160|10:192|11:OBJ_mode
color_table.MD1_MD0=00:4_color_2bpp|01:16_color_4bpp|11:256_color_8bpp
> SCMR controls both the bus ownership AND the screen rendering mode.
> RON and RAN MUST be set to GSU before starting GSU execution (so
> the GSU can access ROM and RAM). They MUST be cleared back to main
> before the main CPU tries to access ROM or RAM. The height + color
> mode set the layout of the GSU's emulated frame buffer in cart RAM.

[SECTION:gsu_memory_map]
main_view_rom_a=$00..$3F:$8000..$FFFF|2_MiB_LoROM_window
main_view_rom_b=$40..$7D:$0000..$FFFF|additional_2_MiB_full_bank_window
main_view_ram_full=$70..$71:$0000..$FFFF|128_KiB_gamepak_RAM
main_view_ram_image=$00..$3F:$6000..$7FFF|8_KiB_window_into_gamepak_RAM
main_view_backup_ram=$78..$79:$0000..$FFFF|128_KiB_battery_RAM
main_view_extra_rom=$80..$BF:$8000..$FFFF|6_MiB_for_main_CPU_only_section
gsu_view_rom=identical_to_main_view_a_and_b|via_PBR_for_code_and_ROMBR_for_data
gsu_view_ram=identical|via_RAMBR_to_pick_$70_or_$71
gsu_view_cache=$0000..$01FF_in_PBR_bank|512_bytes
> The Super FX has its own banked memory model. ROM is split into a
> LoROM-style window for the main CPU and a HiROM-style window for
> direct full-bank access (used by the GSU for executing code). RAM
> is in banks $70..$71 (the gamepak RAM, NOT system WRAM at $7E..$7F).

[SECTION:gsu_instruction_set_summary]
total_instructions=98
prefix_instructions=ALT1_ALT2_ALT3_FROM_TO_WITH|set_flags_for_NEXT_instruction_only
arithmetic=ADD|ADC|SUB|SBC|CMP|MULT|UMULT|FMULT|LMULT|DIV2|INC|DEC
logical=AND|OR|XOR|NOT|BIC
shift=ASR|LSR|ROL|ROR
byte_ops=HIB|LOB|MERGE|SEX|SWAP
jumps=JMP|LJMP_(across_PBR_banks)|BRA|BGE|BLT|BNE|BEQ|BPL|BMI|BCC|BCS|BVC|BVS
loops_links=LOOP|LINK
plot_ops=CMODE|COLOR|PLOT|RPIX|GETC
gsu_control=CACHE|NOP|STOP
mem_to_reg=GETB|GETBH|GETBL|GETBS|LDW|LDB|LM|LMS
reg_to_mem=STW|STB|SM|SMS|SBK
imm_to_reg=IWT|IBT
reg_to_reg=MOVE|MOVES
> The GSU has a clean RISC instruction set. Most ops take 1 cycle when
> executing from cache, longer when reading from ROM or RAM. The plot
> operations PLOT/RPIX are the killer feature: PLOT writes a single
> pixel at (R1, R2) using the COLR color register, with optional
> dithering and transparency via POR. The pipeline writes pixels into
> the cart RAM frame buffer in PPU-compatible format, so the main CPU
> can DMA the result into VRAM without further conversion.

[SECTION:gsu_alt_prefix]
ALT1_$3D=sets_ALT1_flag_for_next_instruction
ALT2_$3E=sets_ALT2_flag_for_next_instruction
ALT3=combination_via_other_means
prefix_clears_after_one_instruction=yes
purpose=expand_opcode_space|same_byte_means_different_op_with_different_prefix
example=ADC_Rn_$50_$5n|ADC_imm_uses_ALT1_prefix_then_$5n
> ALT1/ALT2/ALT3 are 1-byte prefix instructions that don't do anything
> themselves except set a flag. The next instruction's behavior is then
> modified — typically using register addressing in one prefix and
> immediate in another. This effectively quadruples the opcode space.

[SECTION:gsu_register_prefix]
FROM_Rn=sets_source_register_for_next_instruction
TO_Rn=sets_destination_register_for_next_instruction
WITH_Rn=sets_BOTH_source_and_destination_(also_sets_BIRQ)
default=R0_for_both
typical_use=ADD_Rn_form_uses_R0+Rn_unless_FROM_Rm_used_first_to_make_Rm+Rn
> Like ALT prefixes, FROM/TO/WITH are 1-byte prefixes that override the
> implicit R0 source/dest of the next instruction. This is how the GSU
> achieves 3-operand instructions despite having only 1-byte opcodes.

[SECTION:gsu_activation_sequence]
1=main_clears_RON_and_RAN_in_SCMR_$303A_(give_main_temporary_ownership)
2=main_writes_PBR_$3034_to_set_GSU_program_bank
3=main_writes_other_setup_(SCBR_$3038|SCMR_$303A_height_color|CFGR_$3037|CLSR_$3039)
4=main_sets_RON_RAN_in_SCMR_to_grant_GSU_bus_ownership
5=main_writes_R15_$301E_$301F_with_entry_point_-_THIS_STARTS_GSU
6=main_either_runs_in_WRAM_or_polls_SFR.G_for_completion
7=GSU_executes_until_STOP_instruction|then_clears_G_flag_and_optionally_IRQs_main
8=main_clears_RON_RAN_to_reclaim_bus|then_processes_GSU_results
> The activation sequence is critical: any mistake in the order
> typically results in the GSU running on stale data or the main CPU
> reading garbage. The "write to R15" step is what TRIGGERS the GSU —
> until that happens the GSU just sits idle even with the bus granted.

# =============================================================================
# === DSP1, DSP2, DSP3, DSP4 — DETAILED =======================================
# =============================================================================

[SECTION:dsp1_overview_v3]
chip_name=DSP1|variants=DSP1|DSP1A|DSP1B
type=16bit_fixed_point_DSP_based_on_NEC_uPD7725
purpose=pseudo-3D_calculations|trig_tables|coordinate_transforms|matrix_math|projection
internal=command_ROM_with_microcoded_routines|NOT_user_programmable
games_using=Pilotwings|Super_Mario_Kart|Suzuka_8_Hours|Top_Gear_3000|Ace_wo_Nerae|Ballz|various_flight_sims
related_chips=DSP2_(Dungeon_Master)|DSP3_(SD_Gundam_GX)|DSP4_(Top_Gear_3000_Japan)
> DSP1 is a microcoded fixed-point DSP. The chip itself is just a
> generic NEC uPD7725 with custom firmware burned in. Different "DSPn"
> variants have different firmware. From the SNES side they all look
> identical hardware-wise; the difference is which command set the
> firmware implements.

[SECTION:dsp1_communication_v3]
interface=memory_mapped_DR_register|status_register
mode_bits=8bit_or_16bit_select_via_status_register
protocol=main_writes_command_byte_in_8bit_mode|writes_parameters_in_16bit_mode|reads_results_in_16bit_mode
no_handshake_irq=poll_RQM_bit_of_status_register
typical_pattern=write_command|wait_RQM|write_param1|wait_RQM|write_param2|wait_RQM|read_result1|wait_RQM|read_result2
$15_RQM=request_for_master|set_when_DSP_is_ready_for_next_byte_or_word
> Communication is purely byte-by-byte through the DR register. There's
> no DMA support, no IRQ on completion. You poll RQM (D15 of status)
> before each transfer. Command-then-params-then-results is the rhythm.

[SECTION:dsp1_memory_map]
mode_20_DR=$30..$3F:$8000..$BFFF
mode_20_status=$30..$3F:$C000..$FFFF
mode_21_DR=$00..$0F:$6000..$6FFF
mode_21_status=$00..$0F:$7000..$7FFF
> Where the DR and status registers appear depends on the cart's
> mapping mode. Mode 20 (LoROM) puts them in banks $30..$3F upper half;
> Mode 21 (HiROM) puts them in low banks $6000..$7FFF.

[SECTION:dsp1_command_table]
# command_name|opcode|cycle_count|category
multiply=$00|98|general_calc
inverse=$10|98|general_calc
triangle=$04|59|trigonometry|returns_sin_and_cos
radius=$08|34|vector|computes_R^2_from_x,y
range=$18|38|vector|range_compare
distance=$28|156|vector|distance_calc
rotate_2d=$0C|65|coordinate
polar_3d=$1C|147|coordinate
parameter=$02|892|projection_setup|long_setup_for_subsequent_projects
raster=$0A|224+209n|projection|projection_for_n_objects
project=$06|627|projection|object_projection
target=$0E|228|projection|select_screen_point
attitude_a=$01|164|attitude|setup_attitude_matrix_a
attitude_b=$11|164|attitude|alt
attitude_c=$21|164|attitude|alt
objective_a=$0D|45|attitude|global_to_object_space
objective_b=$1D|45
objective_c=$2D|45
subjective_a=$03|44|attitude|object_to_global_space
subjective_b=$13|44
subjective_c=$23|44
scalar_a=$0B|36|attitude|inner_product
scalar_b=$1B|36
scalar_c=$2B|36
gyrate=$14|444|new_angle|3D_angle_rotation
> The command table maps DSP1 opcodes to operations and their cycle
> costs. The most common in flight games are project (627 cycles for
> 3D-to-screen projection) and rotate_2d. Note that DSP1 cycles are
> NOT the same as 65C816 cycles — the DSP1 runs at its own clock and
> reports completion via RQM.

[SECTION:dsp1_parameter_data_types]
A=angle_8bit_or_16bit|range_-pi..+pi
T=fixed_point_decimal_16|range_-1.0..+0.999969
I8=integer_with_decimal_part_16|range_-128.0..+127.996
I=integer_16|range_-32768..+32767
2I=double_integer_16|range_-65536..+65534|step_2
U=unsigned_16
D=double_precision_int_32|range_-2^31..+2^31-1
M=floating_point_coefficient_16
C=floating_point_exponent_16
> All transfers are 16-bit regardless of the parameter's logical size.
> Smaller types are sign-extended or zero-padded to fill 16 bits.

[SECTION:other_coprocessors_briefly]
S_DD1=decompression_chip|used_in_Star_Ocean_and_Street_Fighter_Alpha_2|provides_real_time_LZSS_decompression_during_DMA
SPC7110=decompression_+_RTC_+_extra_addressing|used_in_Tengai_Makyou_Zero_and_Far_East_of_Eden_Zero
CX4=Hitachi_HG51B169_DSP|used_in_Mega_Man_X2_X3_for_polygon_wireframe_effects
ST010=NEC_DSP_used_in_F1_ROC_II|race_AI_calculations
ST011=NEC_DSP_used_in_Hayazashi_Nidan_Morita_Shougi|shogi_AI
ST018=ARM6_processor_used_in_Hayazashi_Nidan_Morita_Shougi_2|shogi_AI
OBC1=memory_remapping_chip|used_in_Metal_Combat
SDD1=variant_of_S_DD1
> The SNES had a thriving ecosystem of coprocessors because the base
> hardware was relatively weak. Each special chip extends the base
> system in a specific way: faster math, decompression, RTC, etc.
> ROM hackers must identify which coprocessor a target ROM uses (via
> the cart type byte $FFD6) before attempting any disassembly because
> the special chip's registers occupy address space that would
> otherwise be reserved or open bus.


# =============================================================================
# === HARDWARE PINOUTS — CONTROLLER, CART, EXPANSION, MULTI-OUT ===============
# =============================================================================

[SECTION:hardware_controller_port_pins]
total_pins=7
pin_1=+5V_power
pin_2=Clock|connected_to_$4016_read_(port_1)_or_$4017_read_(port_2)
pin_3=Latch|connected_to_$4016_write_D0|driving_high_then_low_latches_pad_state
pin_4=Data1|read_via_$4016/$4017_D0
pin_5=Data2|read_via_$4016/$4017_D1|used_by_multitap_for_paired_pads
pin_6=IOBit|connected_to_$4201_$4213|port_1_uses_$4201.D6|port_2_uses_$4201.D7
pin_7=Ground
data_pull=Data1_and_Data2_are_pulled_to_logic_0_inside_SNES|so_unplugged_returns_$0000_(no_buttons)
> When the user reads $4016, the SNES emits a clock pulse on port 1's
> Clock pin. The connected device places its next bit on Data1 (and
> optionally Data2 if it's a paired-pads device like multitap), the
> SNES samples those bits, returns them in $4016.D0 and $4016.D1, and
> the device shifts internally so the next read gives the next bit.
> Port 2 IOBit is special — it's wired to the PPU's external counter
> latch line, so writing 0 to $4201.D7 latches H/V into $213C/$213D.

[SECTION:hardware_cart_connector_pinout]
total_pads=62|two_rows_of_31
address_bus_a=24_bits|A0..A23
data_bus=8_bits|D0..D7
read_write_lines=/RD_(pin_23)|/WR_(pin_54)
auxiliary_lines=/CART_(pin_49)|/WRAM_(pin_32)
address_bus_b=8_bits|PA0..PA7
b_bus_rw=/PARD_(pin_4)|/PAWR_(pin_35)
master_clock_out=21.477MHz_(pin_1)
expand_pin=connects_to_expansion_port_pad_24_(pin_2)
refresh_signal=pin_33|pulses_during_40_cycle_WRAM_refresh_each_scanline
irq_line=/IRQ_(pin_18)|cart_can_drive_low_to_trigger_main_CPU_IRQ
reset_line=/RESET_(pin_26)
cic_pins=24_25_55_56|carry_handshake_with_PPU2_lockout_chip|cart_must_provide_correct_response_or_PPU2_holds_video_in_reset
cpu_clock_out=pin_57|current_CPU_cycle_clock_(6_8_or_12_master_cycles)
audio_in=pin_31_left|pin_62_right|cart_can_inject_audio_to_be_mixed_with_APU_output
> The cart connector exposes the FULL CPU memory bus to the cart, plus
> the entire B bus (PPU register access). This is why special chips
> like SA-1 can be SECOND CPUs that access PPU registers directly. The
> CIC pins are critical: without correct CIC handshake the PPU2 stays
> in reset and the screen is black. This was Nintendo's region lockout
> mechanism. The audio inputs let cart sound chips (like the JVC EX-1)
> mix their output into the SNES audio path.
typical_simple_cart_only_uses=pins_5_27_(power_+_low_address+data)_and_36_58|special_chips_use_remaining_pins
expansion_in_cart=expand_pin_lets_a_cart_communicate_with_a_device_in_the_expansion_port_(very_rare)

[SECTION:hardware_expansion_port_pinout]
total_pads=28
location=on_bottom_of_console
address_bus_b=PA0..PA7|same_as_cart_B_bus
b_bus_rw=/PARD_(pin_10)|/PAWR_(pin_9)
data_bus=D0..D7
reset=pin_19
audio_in_l=pin_27|audio_in_r=pin_28
audio_out_mono=pin_25|mixed_apu_output_signal
irq=pin_26
expand=pin_24|connects_to_cart_pin_2
smpclk=pin_21|approximately_8.192_MHz|3_apu_master_cycles_per_cycle|from_audio_subsystem
dotck=pin_22|approximately_5.369_MHz|21.477/4|from_PPU2|PPU_dot_clock
> The expansion port was Nintendo's mechanism for adding hardware to
> the SNES that wasn't in the cartridge. It was used in Japan for the
> Satellaview broadcast satellite modem and the Sufami Turbo. The
> expansion device gets access to the B bus (so it can read/write PPU
> registers), the data bus, IRQ line, audio mix, and several clock
> signals. SMPCLK and DOTCK let an expansion device synchronize with
> the audio and video subsystems for things like overlay graphics.

[SECTION:hardware_multi_out_pinout]
total_pads=12
pin_1=Red_analog_RGB
pin_2=Green_analog_RGB
pin_3=Composite_H/V_sync_(_+11V_DC_on_PAL_consoles)
pin_4=Blue_analog_RGB
pin_5=Ground
pin_6=Ground
pin_7=S_Video_Y_luminance
pin_8=S_Video_C_chroma
pin_9=Composite_video
pin_10=+5V
pin_11=Mid_sound_(L+R)
pin_12=Side_sound_(L-R)
> The multi-out is genius — a single connector exposing RGB, S-Video,
> and composite video simultaneously, plus stereo audio. Modern RGB
> mods are actually just cables that pick the appropriate pins. PAL
> consoles drive +11V on pin 3 to indicate PAL mode to compatible
> RGB monitors. The "side sound" pin lets some monitors do basic
> stereo separation enhancement.

# =============================================================================
# === COMPRESSION ALGORITHMS COMMONLY USED IN SNES GAMES ======================
# =============================================================================

[SECTION:compression_overview]
purpose=fit_more_graphics_audio_text_into_limited_ROM_space
common_in=RPGs_with_lots_of_text_and_graphics|games_with_2_4_or_8_Mbit_carts
typical_targets=tile_graphics|tilemaps|text_dialogue|sound_data|level_data
custom_per_game=most_games_use_a_proprietary_variant_of_a_well_known_algorithm
common_families=LZ77/LZSS|RLE|Huffman|hybrid
identifying_compression=look_for_routines_that_loop_calling_a_BIT_extract_routine_or_that_have_a_lookup_table_with_specific_offsets
ROM_layout_pattern=compressed_data_typically_at_aligned_offsets_with_an_index_table_at_the_start_of_a_bank

[SECTION:compression_lzss_general]
algorithm=Lempel_Ziv_Storer_Szymanski
type=dictionary_based
mechanism=output_stream_is_either_(a)_literal_byte_or_(b)_back_reference_to_earlier_window
flag_byte=control_byte_with_bit_per_token|0=literal_1=back_reference_or_vice_versa
back_reference_format=2_bytes_typically|byte1_+_byte2.high_=_offset_into_window|byte2.low_=_length_-_3_or_-_threshold
window_size=typical=4096_bytes|some_games_use_2048_or_8192
typical_min_match=3_bytes
> LZSS is the workhorse SNES compression. The encoder maintains a
> sliding window (typically 4 KiB) of recently emitted bytes. When
> compressing, it finds the longest match in the window and emits
> either a literal byte or a (offset, length) back-reference. The
> control byte tells the decoder which kind of token comes next.
> Decompression is just a copy loop that either appends a literal or
> copies bytes from window[offset] to the output (and the window).
common_implementations=Final_Fantasy_VI|Chrono_Trigger|Secret_of_Mana_(custom_variant)|Earthbound

[SECTION:compression_rle_general]
algorithm=Run_Length_Encoding
type=stateless
mechanism=count_byte_followed_by_repeated_value
common_format_1=count_in_high_bit_indicates_run_or_literal|0xxxxxxx=literal_run_of_x+1_bytes_following|1xxxxxxx=repeat_next_byte_x+1_times
common_format_2=fixed_count_byte_then_value_byte
common_format_3=escape_byte_($00_or_$FF)_followed_by_count_then_value_for_runs|other_bytes_are_literal
> RLE is the simplest compression: replace runs of identical bytes
> with a count. SNES games use RLE for tilemaps with large blank areas
> (sky, ground), for sprite tile data with lots of zero pixels, and as
> part of multi-stage compression schemes. Format varies wildly per
> game; the most common is the "high bit selects mode" approach.

[SECTION:compression_lz77_general]
algorithm=Lempel_Ziv_77|original_form_before_LZSS
mechanism=every_token_is_(offset,_length,_next_literal_byte)|even_pure_literals
inefficient_for_high_literal_content=because_offset_length_pair_is_wasted_on_each_literal
mostly_replaced_by_LZSS=on_SNES

[SECTION:compression_lz_huffman_hybrid]
mechanism=LZ77_or_LZSS_followed_by_Huffman_coding_of_the_output_symbols
example_use=Star_Ocean_(via_S_DD1_chip)|some_RPGs_for_text
S_DD1=hardware_decoder_for_LZ_+_arithmetic_coding_combo|allows_compressed_data_to_be_DMAed_into_VRAM_and_decompressed_on_the_fly_during_DMA
SPC7110=hardware_LZSS_decoder_+_higher_level_features

[SECTION:compression_huffman_general]
algorithm=variable_length_prefix_coding
mechanism=more_frequent_symbols_get_shorter_codes
typical_use=text_compression|where_certain_letters_are_much_more_common
implementation=tree_table_at_start_of_data|decoder_walks_tree_one_bit_at_a_time
slow_in_software=requires_bit_extraction_and_tree_walking_for_each_symbol
hardware_assist=SA-1_varlen_unit_does_bit_extraction_in_one_op|S_DD1_does_full_arithmetic_decode

[SECTION:compression_dialogue_text_pattern]
common_pattern=8bit_characters_with_high_bit_set_=_dictionary_index|low_7_bits_=_dictionary_entry_number
dictionary_at_known_location=table_of_pointers_to_substrings|each_substring_is_a_word_or_phrase
example_FF6=$80..$FF_in_text_byte_=_dictionary_lookup|the_dictionary_has_256_common_words_and_phrases
benefit=can_compress_text_to_~50%_with_minimal_decode_overhead|simple_to_implement
typical_setup=encoder_finds_most_common_substrings_in_script|builds_dictionary|recodes_script_with_dictionary_indices_replacing_strings
> The "dictionary substitution" approach is incredibly common in SNES
> RPGs because (a) it has minimal decode CPU cost, (b) the dictionary
> is also human-readable (you can extract it as a wordlist for
> translation), and (c) it gives ~40-60% compression on natural
> language text.

[SECTION:compression_identification_workflow]
step_1=disassemble_the_main_loop_and_find_text_print_routine
step_2=trace_back_from_text_print_to_see_where_data_is_loaded
step_3=look_for_a_routine_that_takes_a_pointer_and_returns_processed_bytes
step_4=examine_that_routine_for_signature_patterns_(LSR_for_huffman_bit_extraction|window_buffer_for_LZSS|count_byte_dispatch_for_RLE)
step_5=test_decompression_by_isolating_the_routine_and_running_it_against_known_input
common_signature_LZSS=loop_with_LDA_(ptr),Y_then_AND_with_$0F_or_$1F_to_extract_length|store_to_window_buffer
common_signature_huffman=loop_with_LSR_to_extract_one_bit_from_a_buffer|tree_walk_via_indexed_lookup
common_signature_dialogue=byte_compare_against_$80_then_index_into_pointer_table

# =============================================================================
# === REVERSE ENGINEERING WORKFLOWS — PRESERVED FROM V2 + EXPANDED ============
# =============================================================================

[SECTION:re_workflow_identify_rom]
step_1=read_$FFC0..$FFDF_for_internal_title_(21_chars_ASCII_or_Shift_JIS)
step_2=read_$FFD5_for_map_mode_byte|$20=LoROM|$21=HiROM|$23=SA-1|$25=ExHiROM|$30=FastLoROM|$31=FastHiROM|$35=FastExHiROM
step_3=read_$FFD6_for_cart_type|$00=ROM_only|$01=ROM+RAM|$02=ROM+RAM+battery|$03=ROM+coprocessor|$04=ROM+co+RAM|$05=ROM+co+RAM+battery|$13=Super_FX|$33=SA-1|$34=SA-1_RAM|$35=SA-1_RAM_battery|$43=S_DD1|$F3=CX4
step_4=read_$FFD7_for_ROM_size|byte_value_=_log2(KB)+10|$09=4Mbit|$0A=8Mbit|$0B=16Mbit|$0C=32Mbit|$0D=48Mbit
step_5=read_$FFD8_for_SRAM_size|byte_value_=_log2(KB)|$00=none|$03=8KB|$05=32KB|$07=128KB
step_6=read_$FFD9_for_country|$00=Japan|$01=NorthAmerica|$02=Europe|$03=Sweden|$04=Finland|$05=Denmark|$06=France|$07=Holland|$08=Spain|$09=Germany|$0A=Italy|$0B=China|$0C=Indonesia|$0D=Korea|$0E=Common|$0F=Canada|$10=Brazil|$11=Australia
step_7=read_$FFDC_$FFDD_for_inverse_checksum_then_$FFDE_$FFDF_for_checksum|complement=$FFFF
step_8=identify_HiROM_vs_LoROM_when_$FFD5_is_ambiguous_by_checking_$00FFC0_vs_$40FFC0_for_valid_title_string
> Step 1 alone is enough to identify most carts. The internal title is
> at a fixed offset relative to the bank base ($FFC0 for HiROM, $7FC0
> for LoROM after copier header offset). Use the title to find the
> game on a database. Steps 2-7 give you the structural info. Step 8
> handles ambiguous carts where the header byte is wrong (some bootlegs).

[SECTION:re_workflow_find_main_loop]
indicator_1=NMI_handler_typically_does_palette_DMA_then_OAM_DMA_then_returns
indicator_2=main_loop_typically_starts_with_WAI_(wait_for_NMI)_then_does_game_logic
indicator_3=look_at_reset_vector_$FFFC_$FFFD_for_entry_point_then_trace_through_init
trace_strategy_1=set_breakpoint_at_NMI_vector_($FFEA_$FFEB)_in_emulator|step_through_to_see_each_frame's_work
trace_strategy_2=look_for_STA_$4200_with_value_$81_(NMI_enable)_to_find_init_complete_point
trace_strategy_3=find_$2100_writes_to_locate_force_blank_management
> The main loop on a typical SNES game is short: WAI to wait for NMI,
> read joypad inputs, run game logic, prepare frame buffers in WRAM
> for the next frame, repeat. Most "interesting" code runs in NMI
> (which moves WRAM-prepared data to VRAM/CGRAM/OAM via DMA) and the
> main loop is just a coordinator. Find the WAI instruction in a tight
> loop and you've found the main game loop dispatcher.

[SECTION:re_workflow_find_palettes]
indicator_1=look_for_$2121_writes_(set_CGADD)_followed_by_$2122_writes
indicator_2=or_DMA_setup_with_BBADx=$22_(destination_$2122)
indicator_3=palette_data_in_ROM_is_typically_512_bytes_per_full_palette_or_32_bytes_per_4bpp_subpalette
identify_in_data=look_for_aligned_blocks_of_15bit_BGR_words|first_color_often_$0000_(transparent)_or_a_distinctive_background
extract_pattern=DMA_setup_with_source_at_palette_data_pointer|count_=_size|destination_$2122
> Palettes are easy to find because the only place they go is $2122,
> and they're typically uploaded with DMA. Search the disassembly for
> #$22 STA $4301 patterns (DMA to CGRAM). The source address tells you
> where the palette data lives in ROM. Once you have that pointer, you
> can extract palettes for color analysis.

[SECTION:re_workflow_find_graphics_uploads]
indicator_1=look_for_$2118_or_$2119_writes_(set_VMDATA)_following_$2116_$2117_(VMADD)
indicator_2=or_DMA_setup_with_BBADx=$18_(destination_$2118)
indicator_3=graphics_data_in_ROM_is_typically_aligned_to_$20_or_$200_byte_boundaries
identify_in_data=4bpp_tile_=_32_bytes|2bpp_tile_=_16_bytes|8bpp_tile_=_64_bytes|look_for_blocks_of_consistent_size
common_destinations=$0000..$1FFF=BG3_chr_(font_or_HUD_tiles)|$1000..$2FFF=BG1_chr|$3000..$5FFF=tilemaps|$4000..$7FFF=OBJ_chr
extract_pattern=DMA_setup_with_BBADx=$18|increment_mode_$80|word_pattern_$01

[SECTION:re_workflow_find_text_routines]
indicator_1=look_for_routines_that_iterate_over_a_pointer_and_branch_on_specific_byte_values
indicator_2=common_control_codes_$00=end|$01=newline|$02=wait_for_input|$03=clear_window|etc
indicator_3=text_data_often_immediately_follows_pointers_in_a_table
indicator_4=if_dictionary_compressed,_look_for_a_compare_with_$80_or_$C0_or_$E0
text_table_pattern=long_pointer_table_at_known_offset_with_consistent_stride|each_pointer_points_to_a_dialogue_string
script_extraction=once_you_find_the_pointer_table_and_control_codes,_dump_each_string_with_a_python_script_that_walks_pointers
> Text/dialogue is usually one of the LARGEST chunks of data in an
> RPG ROM. The routine that prints text iterates one character at a
> time and checks for control codes (newline, pause, color change,
> portrait change, end of message). Identifying control codes is
> critical for translation work because the translation must
> preserve all of them in correct positions.

[SECTION:re_workflow_find_compression]
indicator_1=look_for_routines_that_LSR_or_ROL_through_a_buffer_(bit_extraction)
indicator_2=routines_with_window_buffer_in_WRAM_($00..$0FFF_typical)
indicator_3=routines_called_just_before_a_DMA_to_VRAM
trace_pattern=set_breakpoint_at_$2118_DMA_or_LDA_$2118_loop|trace_back_to_find_what_prepared_the_buffer
common_window_locations=$7E0000..$7E0FFF|$0000..$0FFF_in_direct_page

[SECTION:re_workflow_find_sound_driver]
indicator_1=look_for_long_sequence_of_writes_to_$2140..$2143_at_init_(IPL_upload)
indicator_2=identify_first_block_destination_address_(usually_$0200_for_driver)
indicator_3=extract_uploaded_SPC_data_from_ROM_to_get_the_sound_driver_binary
indicator_4=common_drivers=N_SPC_(Nintendo)|AKAO_(Square)|Bobby_Prince|Konami|custom
n_spc_signature=specific_byte_pattern_at_driver_start
akao_signature=Square_drivers_have_recognizable_command_table_format
> The sound driver lives in the SPC's RAM after upload. To extract it,
> find the IPL upload code in the main CPU init, identify the source
> address of each upload block in ROM, and dump those bytes — they ARE
> the sound driver. Then disassemble in an SPC700 disassembler.

[SECTION:re_workflow_patch_strategy]
strategy_1_inline=patch_bytes_directly_at_target_offsets|simple_for_text_translation_where_strings_are_same_length
strategy_2_jump_table=replace_a_routine_with_JSL_to_expansion_area|put_new_routine_in_unused_bank
strategy_3_pointer_redirect=add_new_data_in_expansion|patch_pointer_table_to_point_at_new_data
strategy_4_full_recompile=disassemble_entire_game,_rebuild_with_modifications
expansion_area=most_carts_have_unused_banks_at_end_of_ROM|map_in_via_LoROM/HiROM_extension
ips_patch=binary_diff_format|sequence_of_(offset,_length,_data)_chunks
bps_patch=better_format_with_checksums_and_compression
ups_patch=intermediate_format

[SECTION:re_workflow_sa1_specific]
identify=$FFD5=$23|$FFD6=$33_or_$34_or_$35
arbitration_concerns=main_CPU_runs_at_2.68MHz_no_FastROM|SA-1_at_10.74MHz
sa1_code_typically_in=banks_$00..$3F_$8000..$FFFF_(LoROM_mirror)
ram_layout=BWRAM_at_$40..$4F:$0000..$FFFF|IRAM_at_$3000..$37FF
debug_strategy=use_emulator_with_dual_CPU_view_(BSNES,_lsnes,_higan)
common_pattern=main_CPU_uploads_input_state_to_BWRAM|writes_$2200_to_signal_SA-1|SA-1_processes|writes_$2301_status|main_polls_or_takes_IRQ

[SECTION:re_workflow_superfx_specific]
identify=$FFD6=$13_or_$1A
gsu_code_typically_in=ROM_with_PBR_set_via_$3034
gsu_data_in_cart_RAM=banks_$70..$71
debug_strategy=emulator_with_GSU_register_view_(BSNES,_higan)
sequence_of_interest=main_writes_to_R15_via_$301E_$301F_to_start_GSU
common_pattern=main_uploads_geometry_data_to_cart_RAM|sets_GSU_PC|polls_SFR.G_for_completion|DMAs_resulting_frame_buffer_to_VRAM

[SECTION:re_workflow_dsp1_specific]
identify=$FFD6=$03_or_$04_or_$05_combined_with_DSP_chip_in_PCB
dsp_calls_typically_in=routines_that_compute_3D_projections_or_trig
trace_strategy=look_for_writes_to_$30..$3F:$8000_(LoROM_DR)_or_$00..$0F:$6000_(HiROM_DR)
common_pattern=write_command_byte|loop_polling_RQM|write_params|loop_polling|read_results

