[SECTION:address_conversion_quick_table]
desc=one_line_per_mapping_for_fast_reference
LoROM_$20=pc=((bank&$7F)<<15)|(addr&$7FFF)
LoROM_$30=same_as_$20
HiROM_$21=pc=((bank&$3F)<<16)|addr
HiROM_$31=same_as_$21
ExHiROM_$25=pc=((bank&$3F)<<16)|addr|((bank&$80)?0:$400000)
ExHiROM_$35=same_as_$25
SA1_$23_direct=pc=(BLOCK.block*$100000)|((bank-window_base)<<16)|addr
SA1_$23_mirror=pc=(BLOCK.block*$100000)|((bank&$1F)<<15)|(addr&$7FFF)
SuperFX_lorom=pc=((bank&$7F)<<15)|(addr&$7FFF)
SuperFX_full=pc=((bank&$3F)<<16)|addr  # $40..$7D
WRAM_$7E_$7F=runtime_only|never_in_pc_space
VRAM=runtime_only|via_$2116_$2117_VMADD
CGRAM=runtime_only|via_$2121_CGADD
OAM=runtime_only|via_$2102_$2103_OAMADD

[SECTION:address_conversion_pseudocode]
desc=reference_implementation_for_writing_tools
> Use this when implementing a SNES disassembler or hex editor. Returns -1
> for non-ROM bus regions. SA-1 case requires the current state of the four
> block registers, which must be tracked while disassembling main CPU code.

function_snes_to_pc=|
  if map_mode==$20 or $30:                                       # LoROM
    if (bank&$40)==0 and addr<$8000: return -1
    return ((bank&$7F)<<15) | (addr&$7FFF)
  elif map_mode==$21 or $31:                                     # HiROM
    if bank in $40..$7D or $C0..$FF: return ((bank&$3F)<<16)|addr
    if (bank<=$3F or bank in $80..$BF) and addr>=$8000:
      return ((bank&$3F)<<16)|addr
    return -1
  elif map_mode==$25 or $35:                                     # ExHiROM
    if bank>=$C0: return ((bank&$3F)<<16)|addr
    if bank in $40..$7D: return ((bank&$3F)<<16)|addr|$400000
    if bank in $80..$BF and addr>=$8000: return ((bank&$3F)<<16)|addr
    if bank<=$3F and addr>=$8000: return ((bank&$3F)<<16)|addr|$400000
    return -1
  elif map_mode==$23:                                            # SA-1
    if bank in $C0..$CF: return (CXB.block*$100000)|((bank-$C0)<<16)|addr
    if bank in $D0..$DF: return (DXB.block*$100000)|((bank-$D0)<<16)|addr
    if bank in $E0..$EF: return (EXB.block*$100000)|((bank-$E0)<<16)|addr
    if bank in $F0..$FF: return (FXB.block*$100000)|((bank-$F0)<<16)|addr
    if bank in $00..$1F and addr>=$8000: return (CXB.block*$100000)|((bank&$1F)<<15)|(addr&$7FFF)
    if bank in $20..$3F and addr>=$8000: return (DXB.block*$100000)|((bank&$1F)<<15)|(addr&$7FFF)
    if bank in $80..$9F and addr>=$8000: return (EXB.block*$100000)|((bank&$1F)<<15)|(addr&$7FFF)
    if bank in $A0..$BF and addr>=$8000: return (FXB.block*$100000)|((bank&$1F)<<15)|(addr&$7FFF)
    return -1

function_detect_map_mode=|
  candidates=[(LoROM,$7FB0),(HiROM,$00FFB0),(ExHiROM,$40FFB0)]
  for (mode,offset) in candidates:
    score=0
    if rom[offset+$1A]==$33: score+=2
    cs=rom[offset+$1E]|(rom[offset+$1F]<<8)
    cc=rom[offset+$1C]|(rom[offset+$1D]<<8)
    if (cs^cc)==$FFFF: score+=4
    if rom[offset+$15]==expected_byte_for(mode): score+=2
    if all_printable_ascii(rom[offset..offset+$15]): score+=1
    if score>=5: return mode
  return UNKNOWN

# =============================================================================
# === SYSTEM OVERVIEW & CYCLE/CLOCK FUNDAMENTALS ===============================
# =============================================================================

[SECTION:system_overview]
desc=high_level_system_architecture
cpu_main=Ricoh_5A22|65C816_core_+_custom_periph
cpu_main_clocks=3.58_MHz_fast|2.68_MHz_normal|1.79_MHz_slow_IO
ppu_chips=PPU1=5C77|PPU2=5C78|cooperate_to_drive_video
apu=isolated_subsystem|SPC700@2.048MHz_+_S-DSP|own_64KiB_RAM
wram=128KiB|vram=64KiB|oam=544B|cgram=512B
dma_channels=8_shared_GPDMA_HDMA
master_clock_hz_ntsc=21477272
master_clock_hz_pal=21281370
ntsc_lines_per_frame=262
pal_lines_per_frame=312
visible_lines=224_default|239_with_$2133.D2
pixels_per_line=256_normal|512_in_modes_5_6
> The system is built around a 21.477 MHz NTSC (or 21.281 MHz PAL) master
> clock that drives every subsystem. The CPU runs at master/6 (fast, 3.58
> MHz), master/8 (normal, 2.68 MHz), or master/12 (slow, 1.79 MHz) depending
> on which memory region is being accessed. The PPU runs continuously at
> master/4 producing one pixel every 4 master clocks. The APU is on a totally
> separate ~2.048 MHz crystal and communicates only through 4 mailbox ports.
>
> One scanline = 1364 master clocks = ~341 fast CPU cycles = 256 pixels +
> 85.5 pixels of horizontal blank. One full NTSC frame = 262*1364 = 357,368
> master clocks = ~16.64 ms = ~59.94 Hz. The visible region is 224 lines by
> default (or 239 with bit 2 of $2133 set), and the rest is V-blank during
> which the CPU can safely upload to VRAM/OAM/CGRAM.

[SECTION:master_clock_and_cycle_relationships]
desc=clock_domain_arithmetic_for_cycle_accurate_work
master_hz_ntsc=21477272
master_hz_pal=21281370
master_per_dot=4|one_pixel_dot=4_master_cycles
dots_per_scanline=341.33|but_actually_1364_master_div_4=341
master_per_scanline=1364
scanlines_ntsc=262
scanlines_pal=312
master_per_frame_ntsc=357368
master_per_frame_pal=425568
frame_rate_ntsc_hz=60.0988
frame_rate_pal_hz=50.0070
fast_cpu_cycle_master=6  # 3.58 MHz
normal_cpu_cycle_master=8  # 2.68 MHz
slow_cpu_cycle_master=12  # 1.79 MHz
fast_cpu_cycles_per_scanline=1364/6=227.33
normal_cpu_cycles_per_scanline=1364/8=170.5
visible_scanlines=0..224
vblank_scanlines_ntsc=225..261|approximately_37_lines
vblank_scanlines_pal=240..311|approximately_72_lines
vblank_duration_us_ntsc=approx_2730us
vblank_duration_us_pal=approx_4600us
> Cycle-accurate work requires understanding that "one CPU cycle" is not a
> fixed amount of time. Each memory access uses the appropriate clock for
> the region being touched: WRAM and most registers are 8 master cycles
> (normal speed); ROM in $80..$FF can be 6 master cycles (fast) IF the game
> sets $420D bit 0 AND the cart supports it; the joypad I/O at $4016/$4017
> and a few neighboring addresses are 12 master cycles (slow). A single
> 65816 instruction therefore has variable wall-clock duration even if its
> "cycle count" is fixed.
>
> The PAL system has more vblank lines (72 vs 37) which means PAL games
> have more time per frame for VRAM/OAM uploads. NTSC games typically use
> ~6 KiB of VRAM upload per frame budget; PAL games can do more.

[SECTION:cpu_speed_regions]
desc=which_address_runs_at_which_clock_speed
fast_3.58_MHz_eligible=$80..$BF:$8000..$FFFF|$C0..$FF:$0000..$FFFF
fast_3.58_MHz_actual=only_when_$420D.D0=1_AND_cartridge_wires_FastROM
normal_2.68_MHz=$00..$3F:$0000..$1FFF_(WRAM_mirror)
normal_2.68_MHz=$00..$3F:$2000..$3FFF_(PPU_APU_regs)
normal_2.68_MHz=$00..$3F:$4200..$5FFF_(CPU_regs)
normal_2.68_MHz=$00..$3F:$6000..$7FFF_(expansion_or_HiROM_SRAM)
normal_2.68_MHz=$00..$7D:$8000..$FFFF_(LoROM_or_HiROM_first_half)
normal_2.68_MHz=$7E..$7F_(WRAM)
slow_1.79_MHz=$00..$3F:$4000..$41FF_(joypad_old_style)
default_at_reset=$420D.D0=0|all_addresses_use_normal_or_slow
fastrom_enable=write_$01_to_$420D|then_$80+_banks_run_at_3.58_MHz
> Most games leave FastROM disabled and just run everything at 2.68 MHz.
> Games that opt into FastROM (Star Fox, Yoshi's Island, Doom, Donkey Kong
> Country, etc) typically execute the bulk of their code from $80..$FF
> banks where the speedup applies. Note that even with FastROM enabled,
> WRAM access is still 2.68 MHz and joypad-area access is 1.79 MHz, so
> tight loops touching WRAM see no speedup.

